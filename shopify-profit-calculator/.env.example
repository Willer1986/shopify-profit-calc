# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, PlanetScale, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/shopify_calculator"

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-min-32-chars"

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# Create a Product + Price in Stripe Dashboard, copy the Price ID
# Price should be: $9 / month, recurring
STRIPE_PRO_PRICE_ID="price_..."

# ─── Public App URL ─────────────────────────────────────────────────────────────
# No trailing slash
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of emails with access to /admin
ADMIN_EMAILS="you@example.com"

# ─── Optional: Email (for contact form) ────────────────────────────────────────
# Uncomment and configure your email provider in src/app/api/contact/route.ts
# RESEND_API_KEY="re_..."
